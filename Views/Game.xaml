<Window x:Class="Spanzuratoare.Views.Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Spanzuratoare.ViewModels" 
        Title="Game" Height="520" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFB8ACFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
        <Menu Background="#FF6D4ED9" Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Background="#FF6D4ED9" Header="_File" Foreground="White">
                <MenuItem Background="#FF6D4ED9" Header="_New Game" Command="{Binding NewGameCommand}"/>
                <MenuItem Background="#FF6D4ED9" Header="_Open Game" Command="{Binding LoadCommand}"/>
                <MenuItem Background="#FF6D4ED9" Header="_Save Game" Command="{Binding SaveCommand}"/>
                <MenuItem Background="#FF6D4ED9" Header="_Statistics" Command="{Binding StatisticsCommand}"/>
                <Separator/>
                <MenuItem Background="#FF6D4ED9" Header="_Exit" Command="{Binding CancelCommand}"/>
            </MenuItem>
            <MenuItem Header="_Categories" Foreground="White">

                <MenuItem Header="_All categories"
                Command="{Binding SelectCategoryCommand}"
                CommandParameter="All"
                Background="#FF6D4ED9"/>

                <MenuItem Header="_Movies"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Movies"
              Background="#FF6D4ED9"/>

                <MenuItem Header="_Music"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Music"
              Background="#FF6D4ED9"/>

                <MenuItem Header="_Animals"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Animals"
              Background="#FF6D4ED9"/>

                <MenuItem Header="_Characters"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Characters"
              Background="#FF6D4ED9"/>

                <MenuItem Header="_Countries"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Countries"
              Background="#FF6D4ED9"/>

                <MenuItem Header="_Games"
              Command="{Binding SelectCategoryCommand}"
              CommandParameter="Games"
              Background="#FF6D4ED9"/>

            </MenuItem>
            <MenuItem Header="_Help" Foreground="White">
                <MenuItem Background="#FF6D4ED9" Header="_About"
                          Command="{Binding HelpCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock FontSize="18" HorizontalAlignment="Center">
                <TextBlock.Text>
                    <Binding Path="Level" StringFormat="Nivel: {0}"/>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock FontSize="18" HorizontalAlignment="Right" Grid.Column="1">
                <TextBlock.Text>
                    <Binding Path="TimeLeft" StringFormat="Timer: {0} secunde"/>
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0" Margin="10">

            <Image 
                   Stretch="Uniform"
                   Source="{Binding CurrentHangmanImage}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

        </Grid>

        <Grid Grid.Row="2" Grid.Column="1" Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ItemsControl Grid.Row="1"
                          Margin="0,20,0,20"
                          ItemsSource="{Binding WordDisplay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding}"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                            <Rectangle Width="16" Height="3" Fill="Black" Margin="5"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2" BorderThickness="2" Padding="15">
                <WrapPanel Width="460" HorizontalAlignment="Center" Margin="0,0,0,-7">
                    <Button Content="A" Command="{Binding GuessLetterCommand}" CommandParameter="A" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="B" Command="{Binding GuessLetterCommand}" CommandParameter="B" Width="40" Height="40" Margin="5" Background="White" />
                    <Button Content="C" Command="{Binding GuessLetterCommand}" CommandParameter="C" Width="40" Height="40" Margin="5" Background="White" />
                    <Button Content="D" Command="{Binding GuessLetterCommand}" CommandParameter="D" Width="40" Height="40" Margin="5" Background="White" />
                    <Button Content="E" Command="{Binding GuessLetterCommand}" CommandParameter="E" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="F" Command="{Binding GuessLetterCommand}" CommandParameter="F" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="G" Command="{Binding GuessLetterCommand}" CommandParameter="G" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="H" Command="{Binding GuessLetterCommand}" CommandParameter="H" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="I" Command="{Binding GuessLetterCommand}" CommandParameter="I" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="J" Command="{Binding GuessLetterCommand}" CommandParameter="J" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="K" Command="{Binding GuessLetterCommand}" CommandParameter="K" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="L" Command="{Binding GuessLetterCommand}" CommandParameter="L" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="M" Command="{Binding GuessLetterCommand}" CommandParameter="M" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="N" Command="{Binding GuessLetterCommand}" CommandParameter="N" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="O" Command="{Binding GuessLetterCommand}" CommandParameter="O" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="P" Command="{Binding GuessLetterCommand}" CommandParameter="P" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="Q" Command="{Binding GuessLetterCommand}" CommandParameter="Q" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="R" Command="{Binding GuessLetterCommand}" CommandParameter="R" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="S" Command="{Binding GuessLetterCommand}" CommandParameter="S" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="T" Command="{Binding GuessLetterCommand}" CommandParameter="T" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="U" Command="{Binding GuessLetterCommand}" CommandParameter="U" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="V" Command="{Binding GuessLetterCommand}" CommandParameter="V" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="W" Command="{Binding GuessLetterCommand}" CommandParameter="W" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="X" Command="{Binding GuessLetterCommand}" CommandParameter="X" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="Y" Command="{Binding GuessLetterCommand}" CommandParameter="Y" Width="40" Height="40" Margin="5" Background="White"/>
                    <Button Content="Z" Command="{Binding GuessLetterCommand}" CommandParameter="Z" Width="40" Height="40" Margin="5" Background="White"/>

                </WrapPanel>
            </Border>

        </Grid>

        <Grid Grid.Row="3" Grid.Column="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="{Binding SelectedUser.ProfilePicture}"
                   Width="80" Height="80"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding SelectedUser.Name}"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </Grid>
        
        <StackPanel Grid.Row="3" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top" Margin="0,15,0,0">

            <ItemsControl ItemsSource="{Binding Hearts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="❤" FontSize="30">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Red"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="False">
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </DataTrigger>
                                    </Style.Triggers>

                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </Grid>
</Window>