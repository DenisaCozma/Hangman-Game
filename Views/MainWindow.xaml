<Window x:Class="Spanzuratoare.Views.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:vm="clr-namespace:Spanzuratoare.ViewModels" 
        Title="StartGame" Height="520" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainWindowMV/>
    </Window.DataContext>
    <Grid Background="#FFB8ACFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Welcome to Hangman! Enjoy this game!" FontSize="30" FontWeight="Bold" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20,0,10">
            <TextBlock.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF250F58" Offset="0"/>
                    <GradientStop Color="#FF774BDF" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Foreground></TextBlock>
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
        Padding="5"
        CornerRadius="12"
        Background="White"
        BorderBrush="#FF6D4ED9"
        BorderThickness="3">

                <ListBox ItemsSource="{Binding Users}" 
             SelectedItem="{Binding SelectedUser}" 
             DisplayMemberPath="Name"
             Name="UserList"
             Background="Transparent"
             BorderThickness="3" BorderBrush="{x:Null}"/>
            </Border>
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Width="260" Height="260" BorderThickness="2" HorizontalAlignment="Center">
                    <Image x:Name="ProfilePicture" Source="{Binding SelectedUser.ProfilePicture}" Stretch="Uniform"/>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="New User" Margin="10" Command="{Binding OpenNewUserCommand}"
        Background="#FF6D4ED9" Foreground="White"
        FontWeight="SemiBold" FontSize="16"
        BorderThickness="0" Cursor="Hand"
        Height="50">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" Content="Delete User" Margin="10" Command="{Binding DeleteUserCommand}"
        Background="#FF6D4ED9" Foreground="White"
        FontWeight="SemiBold" FontSize="16"
        BorderThickness="0" Cursor="Hand"
        Height="50">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF8C76D9"/>
                            </Trigger>
                            </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Content="Play" Margin="10" Command="{Binding OpenNewGameCommand}"
        Background="#FF6D4ED9" Foreground="White"
        FontWeight="SemiBold" FontSize="17"
        BorderThickness="0" Cursor="Hand"
        Height="50">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF8C76D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="3" Content="Cancel" Margin="10"
        Background="#FF6D4ED9" Foreground="White"
        FontWeight="SemiBold" FontSize="16"
        BorderThickness="0" Cursor="Hand"
        Height="50">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>